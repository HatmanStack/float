{
  "name": "float-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "cd frontend && npm start",
    "android": "cd frontend && npm run android",
    "ios": "cd frontend && npm run ios",
    "web": "cd frontend && npm run web",
    "test": "cd frontend && npx jest --forceExit",
    "test:backend": "cd backend && PYTHONPATH=. pytest tests/unit -v --tb=short",
    "lint": "cd frontend && npm run lint",
    "lint:backend": "cd backend && uvx ruff check .",
    "check": "npm run lint && npm run lint:backend && npm test && npm run test:backend",
    "test:backend:docker": "docker compose run --rm backend",
    "deploy": "node ./backend/scripts/deploy.mjs",
    "prepare": "husky",
    "setup": "npm install --legacy-peer-deps && cd backend && python3 -m pip install -r requirements.txt -r requirements-dev.txt && cd .. && echo 'Setup complete. Copy .env.example files to .env and fill in your API keys.'"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "detox": "^20.0.0",
    "expo": "~55.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.3"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "./frontend/node_modules/.bin/eslint --config ./frontend/eslint.config.js --fix",
      "prettier --write"
    ],
    "frontend/**/*.json": [
      "prettier --write"
    ],
    "backend/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  }
}
